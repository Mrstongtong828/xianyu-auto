{
  "publish_url": "https://www.goofish.com/publish",
  "title_selectors": [
    "input[placeholder*=\"标题\"]",
    "textarea[placeholder*=\"标题\"]",
    "input[name*=\"title\"]",
    "textarea[name*=\"title\"]",
    "[contenteditable=\"true\"][aria-label*=\"标题\"]"
  ],
  "description_selectors": [
    "textarea[placeholder*=\"描述\"]",
    "textarea[placeholder*=\"详情\"]",
    "[contenteditable=\"true\"][aria-label*=\"描述\"]",
    "[contenteditable=\"true\"][aria-label*=\"详情\"]",
    "textarea[name*=\"desc\"]"
  ],
  "price_selectors": [
    "input[placeholder*=\"价格\"]",
    "input[placeholder*=\"售价\"]",
    "input[placeholder*=\"0.00\"]",
    "input[name*=\"price\"]",
    "input[type=\"number\"]"
  ],
  "category_selectors": [
    "input[placeholder*=\"类目\"]",
    "input[placeholder*=\"分类\"]",
    "input[placeholder*=\"搜索\"]",
    "input[name*=\"category\"]"
  ],
  "file_input_selectors": [
    "input[type=\"file\"][accept*=\"image\"]",
    "input[type=\"file\"]"
  ],
  "upload_trigger_selectors": [
    "text=添加首图",
    "text=宝贝图片",
    "text=上传图片",
    "button:has-text(\"添加\")",
    "[aria-label*=\"上传\"]",
    "[class*=\"upload\"]"
  ],
  "risk_keywords": [
    "验证码",
    "安全验证",
    "滑块",
    "风控",
    "验证身份",
    "passport.goofish.com",
    "passport.taobao.com",
    "punish",
    "captcha"
  ]
}
